{
  "name": "@figedi/sentry-fastify",
  "version": "1.0.6",
  "description": "A request-/tracing-middleware for sentry in fastify",
  "license": "MIT",
  "author": "Felix Kaminski",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "format": "run-s format:prettier format:eslint",
    "format:eslint": "eslint --cache --ext .ts,.tsx --fix ./ >/dev/null 2>&1 || true",
    "format:prettier": "prettier --write 'src/**/*.{ts,tsx}'",
    "lint": "eslint --ext ts,tsx src"
  },
  "dependencies": {
    "@sentry/node": "^7.1.1",
    "@sentry/tracing": "^7.1.1",
    "@sentry/integrations": "^7.1.1",
    "@sentry/core": "^7.1.1",
    "@sentry/utils": "^7.1.1",
    "fastify": "4.0.2",
    "fastify-plugin": "^3.0.1"
  },
  "devDependencies": {
    "@types/node": "^17.0.42",
    "@sentry/types": "^7.1.1",
    "@typescript-eslint/eslint-plugin": "^5.27.1",
    "@typescript-eslint/parser": "^5.27.1",
    "eslint": "^8.17.0",
    "eslint-config-airbnb-typescript": "^17.0.0",
    "eslint-config-prettier": "^8.5.0",
    "eslint-plugin-import": "^2.26.0",
    "eslint-plugin-prettier": "^4.0.0",
    "npm-run-all": "^4.1.5",
    "prettier": "^2.6.2",
    "typescript": "^4.7.3"
  }
}
