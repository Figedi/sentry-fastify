{
  "name": "@figedi/sentry-fastify",
  "version": "1.0.1",
  "description": "A request-/tracing-middleware for sentry in fastify",
  "license": "MIT",
  "author": "Felix Kaminski",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "format": "run-s format:prettier format:eslint",
    "format:eslint": "eslint --cache --ext .ts,.tsx --fix ./ >/dev/null 2>&1 || true",
    "format:prettier": "prettier --write 'src/**/*.{ts,tsx}'",
    "lint": "eslint --ext ts,tsx src"
  },
  "dependencies": {
    "@sentry/node": "^6.9.0",
    "@sentry/tracing": "^6.9.0",
    "@sentry/integrations": "^6.9.0",
    "@sentry/core": "^6.9.0",
    "@sentry/utils": "^6.9.0",
    "fastify": "3.1.1",
    "fastify-plugin": "2.0.3"
  },
  "devDependencies": {
    "@types/node": "^16.9.1",
    "@sentry/types": "^6.9.0",
    "@typescript-eslint/eslint-plugin": "^4.6.1",
    "@typescript-eslint/parser": "^4.6.1",
    "eslint": "^7.0.0",
    "eslint-config-airbnb-typescript": "^12.0.0",
    "eslint-config-prettier": "^6.15.0",
    "eslint-plugin-import": "^2.22.1",
    "eslint-plugin-prettier": "^3.1.4",
    "npm-run-all": "^4.1.5",
    "prettier": "^2.1.2",
    "typescript": "^4.0.5"
  }
}
